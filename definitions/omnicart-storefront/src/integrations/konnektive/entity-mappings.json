{
  "entityMappings": {
    "customer": {
      "description": "Customer entity field mappings between Konnektive and Medusa",
      "primaryIdentifier": "konnektive_customer_id",
      "secondaryIdentifier": "email",
      "duplicatePreventionStrategy": "metadata_first_then_email",
      "fieldMappings": {
        "customerId": {
          "medusaField": "metadata.konnektive_customer_id",
          "type": "string",
          "required": true,
          "duplicateCheck": true
        },
        "firstName": {
          "medusaField": "first_name",
          "type": "string",
          "required": false
        },
        "lastName": {
          "medusaField": "last_name", 
          "type": "string",
          "required": false
        },
        "emailAddress": {
          "medusaField": "email",
          "type": "string",
          "required": true,
          "duplicateCheck": true
        },
        "phoneNumber": {
          "medusaField": "phone",
          "type": "string",
          "required": false
        },
        "dateCreated": {
          "medusaField": "created_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        },
        "dateUpdated": {
          "medusaField": "updated_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        }
      },
      "metadataFields": [
        "companyName",
        "gender", 
        "dateOfBirth",
        "campaignId",
        "affiliateId",
        "subAffiliateId",
        "sourceValue1",
        "sourceValue2", 
        "sourceValue3",
        "emailOptIn",
        "smsOptIn",
        "marketingOptIn",
        "custom1",
        "custom2",
        "custom3",
        "custom4",
        "custom5"
      ]
    },
    "product": {
      "description": "Product/Variant entity field mappings between Konnektive and Medusa",
      "primaryIdentifier": "konnektive_product_id",
      "secondaryIdentifier": "sku",
      "duplicatePreventionStrategy": "metadata_first_then_sku",
      "fieldMappings": {
        "productId": {
          "medusaField": "metadata.konnektive_product_id",
          "type": "string",
          "required": true,
          "duplicateCheck": true
        },
        "productSku": {
          "medusaField": "sku",
          "type": "string",
          "required": false,
          "duplicateCheck": true,
          "fallbackGeneration": "KON-{productId}"
        },
        "productName": {
          "medusaField": "title",
          "type": "string",
          "required": false,
          "fallbackGeneration": "Product {productId}"
        },
        "productPrice": {
          "medusaField": "prices[].amount",
          "type": "number",
          "required": false,
          "transformation": "multiply_by_100"
        },
        "stockQuantity": {
          "medusaField": "inventory_quantity",
          "type": "number",
          "required": false,
          "default": 0
        },
        "dateCreated": {
          "medusaField": "created_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        }
      },
      "metadataFields": [
        "productDescription",
        "productCategory",
        "productType",
        "weight",
        "dimensions",
        "trackInventory",
        "allowBackorders",
        "custom1",
        "custom2",
        "custom3"
      ]
    },
    "order": {
      "description": "Order entity field mappings between Konnektive and Medusa",
      "primaryIdentifier": "konnektive_order_id",
      "duplicatePreventionStrategy": "metadata_only",
      "fieldMappings": {
        "orderId": {
          "medusaField": "metadata.konnektive_order_id",
          "type": "string",
          "required": true,
          "duplicateCheck": true
        },
        "customerId": {
          "medusaField": "customer_id",
          "type": "string",
          "required": true,
          "resolution": "resolve_customer_first"
        },
        "totalAmount": {
          "medusaField": "total",
          "type": "number",
          "required": false,
          "transformation": "multiply_by_100"
        },
        "taxAmount": {
          "medusaField": "tax_total",
          "type": "number",
          "required": false,
          "transformation": "multiply_by_100"
        },
        "shippingPrice": {
          "medusaField": "shipping_total",
          "type": "number",
          "required": false,
          "transformation": "multiply_by_100"
        },
        "discountAmount": {
          "medusaField": "discount_total",
          "type": "number",
          "required": false,
          "transformation": "multiply_by_100"
        },
        "orderStatus": {
          "medusaField": "status",
          "type": "string",
          "required": false,
          "mapping": {
            "COMPLETE": "completed",
            "PARTIAL": "requires_action",
            "REFUNDED": "canceled",
            "CANCELLED": "canceled",
            "HOLD": "pending",
            "PENDING": "pending",
            "PROCESSING": "pending"
          }
        },
        "paymentStatus": {
          "medusaField": "payment_status",
          "type": "string",
          "required": false,
          "mapping": {
            "PAID": "captured",
            "PARTIAL": "partially_refunded",
            "REFUNDED": "refunded",
            "UNPAID": "not_paid",
            "PENDING": "awaiting"
          }
        },
        "dateCreated": {
          "medusaField": "created_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        },
        "shipDate": {
          "medusaField": "shipped_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        },
        "deliveryDate": {
          "medusaField": "delivered_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        }
      },
      "metadataFields": [
        "campaignId",
        "orderType",
        "paymentMethod",
        "cardType",
        "cardLast4",
        "cardBin",
        "transactionId",
        "paymentId",
        "gatewayId",
        "gatewayResponse",
        "gatewayTransactionId",
        "authCode",
        "responseCode",
        "reasonCode",
        "declineReason",
        "avsCode",
        "cvvCode",
        "fraudScore",
        "fraudReviewStatus",
        "riskLevel",
        "shippingMethod",
        "trackingNumber",
        "carrier",
        "discountCode",
        "taxRate",
        "affiliateId",
        "subAffiliateId",
        "custom1",
        "custom2",
        "custom3",
        "custom4",
        "custom5",
        "sourceValue1",
        "sourceValue2",
        "sourceValue3"
      ],
      "addressMappings": {
        "billing": {
          "firstName": "first_name",
          "lastName": "last_name",
          "address1": "address_1",
          "address2": "address_2",
          "city": "city",
          "state": "province",
          "postalCode": "postal_code",
          "country": "country_code",
          "phoneNumber": "phone"
        },
        "shipping": {
          "shipFirstName": "first_name",
          "shipLastName": "last_name", 
          "shipAddress1": "address_1",
          "shipAddress2": "address_2",
          "shipCity": "city",
          "shipState": "province",
          "shipPostalCode": "postal_code",
          "shipCountry": "country_code"
        }
      }
    },
    "payment": {
      "description": "Payment/Transaction entity field mappings between Konnektive and Medusa",
      "primaryIdentifier": "konnektive_transaction_id",
      "duplicatePreventionStrategy": "metadata_only",
      "fieldMappings": {
        "transactionId": {
          "medusaField": "metadata.konnektive_transaction_id",
          "type": "string",
          "required": true,
          "duplicateCheck": true
        },
        "orderId": {
          "medusaField": "order_id",
          "type": "string",
          "required": true
        },
        "transactionAmount": {
          "medusaField": "amount",
          "type": "number",
          "required": false,
          "transformation": "multiply_by_100"
        },
        "currency": {
          "medusaField": "currency_code",
          "type": "string",
          "required": false,
          "default": "USD"
        },
        "transactionDate": {
          "medusaField": "captured_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        }
      },
      "metadataFields": [
        "customerId",
        "transactionType",
        "transactionStatus",
        "transactionTime",
        "paymentMethod",
        "cardType",
        "cardLast4",
        "cardBin",
        "gatewayId",
        "gatewayTitle",
        "gatewayResponse",
        "gatewayTransactionId",
        "authCode",
        "responseCode",
        "reasonCode",
        "avsCode",
        "cvvCode",
        "fraudScore",
        "fraudReviewStatus",
        "riskLevel",
        "declineReason"
      ]
    },
    "fulfillment": {
      "description": "Fulfillment entity field mappings between Konnektive and Medusa",
      "primary Identifier": "konnektive_fulfillment_id",
      "duplicatePreventionStrategy": "metadata_only",
      "fieldMappings": {
        "fulfillmentId": {
          "medusaField": "metadata.konnektive_fulfillment_id",
          "type": "string",
          "required": true,
          "duplicateCheck": true
        },
        "orderId": {
          "medusaField": "order_id",
          "type": "string",
          "required": true
        },
        "trackingNumber": {
          "medusaField": "tracking_number",
          "type": "string",
          "required": false
        },
        "carrier": {
          "medusaField": "shipping_option.name",
          "type": "string",
          "required": false,
          "fallback": "carrierService",
          "default": "Standard Shipping"
        },
        "shipDate": {
          "medusaField": "shipped_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        },
        "deliveryDate": {
          "medusaField": "delivered_at",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "required": false,
          "syncStrategy": "use_konnektive_date"
        }
      },
      "metadataFields": [
        "carrierService",
        "fulfillmentStatus"
      ]
    }
  },
  "dateSynchronization": {
    "strategy": "use_konnektive_dates_with_fallback",
    "description": "Use Konnektive dates when available, fallback to current time",
    "konnektiveDateFormat": "YYYY-MM-DD HH:mm:ss",
    "medusaDateFormat": "ISO 8601",
    "validationRules": {
      "minDate": "2000-01-01",
      "maxDate": "current_year + 1",
      "requireValidDate": false,
      "fallbackOnInvalid": true
    },
    "dateFields": {
      "created_at": {
        "source": "dateCreated",
        "fallback": "current_timestamp",
        "validation": true
      },
      "updated_at": {
        "source": "dateUpdated", 
        "fallback": "current_timestamp",
        "validation": true
      },
      "shipped_at": {
        "source": "shipDate",
        "fallback": null,
        "validation": true,
        "entityTypes": ["order", "fulfillment"]
      },
      "delivered_at": {
        "source": "deliveryDate",
        "fallback": null,
        "validation": true,
        "entityTypes": ["order", "fulfillment"]
      },
      "captured_at": {
        "source": "transactionDate",
        "fallback": null,
        "validation": true,
        "entityTypes": ["payment"]
      }
    }
  },
  "uniqueIdentifiers": {
    "customer": {
      "primary": "metadata.konnektive_customer_id",
      "secondary": "email",
      "conflictResolution": "link_existing_to_konnektive_id"
    },
    "product": {
      "primary": "metadata.konnektive_product_id",
      "secondary": "sku",
      "conflictResolution": "link_existing_to_konnektive_id"
    },
    "order": {
      "primary": "metadata.konnektive_order_id",
      "conflictResolution": "prevent_duplicates"
    },
    "payment": {
      "primary": "metadata.konnektive_transaction_id",
      "conflictResolution": "prevent_duplicates"
    },
    "fulfillment": {
      "primary": "metadata.konnektive_fulfillment_id",
      "conflictResolution": "prevent_duplicates"
    }
  },
  "transactionHandling": {
    "description": "All findOrCreate operations use database transactions for consistency",
    "isolationLevel": "READ_COMMITTED",
    "timeout": 30000,
    "retryPolicy": {
      "maxRetries": 3,
      "backoffMs": 1000,
      "exponentialBackoff": true
    }
  },
  "errorHandling": {
    "duplicateResolution": {
      "customer": "update_existing_with_konnektive_metadata",
      "product": "update_existing_with_konnektive_metadata", 
      "order": "return_existing",
      "payment": "return_existing",
      "fulfillment": "return_existing"
    },
    "conflictTracking": {
      "enabled": true,
      "reportConflicts": true,
      "maxConflictsPerEntity": 10
    },
    "logging": {
      "level": "info",
      "includeKonnektiveData": false,
      "includeMedusaIds": true,
      "logResolutionMethod": true
    }
  }
}